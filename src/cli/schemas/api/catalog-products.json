      "method": "GET",
      "path": "/stores/{storeId}/categories",
      "summary": "Get categories",
      "description": "This endpoint can be used to retrieve the list of all product categories for a specific store using the store ID.",
      "parameters": [
        {
          "name": "sortBy",
          "in": "query",
          "required": false,
          "description": "Sort categories by name or last updated",
          "schema": {
            "type": "string",
            "default": "updated_at",
            "enum": ["updated_at", "name", "sequence"]
          }
        },
        {
          "name": "sortOrder",
          "in": "query",
          "required": false,
          "description": "Sort categories in descending or ascending order",
          "schema": {
            "type": "string",
            "default": "desc",
            "enum": ["asc", "desc"]
          }
        },
        {
          "name": "ids",
          "in": "query",
          "required": false,
          "description": "Filter results to only include categories that have these UUIDs (comma-separated list).\nMaximum of 50 ids per request.\n\n*Note*: Pagination is currently not supported when using this filter. Other filters are ignored when this one is received.\n",
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "parentId",
          "in": "query",
          "required": false,
          "description": "Filter categories by parent",
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        },
        {
          "name": "altId",
          "in": "query",
          "required": false,
          "description": "Filter results to only include a category with this altId",
          "schema": {
            "$ref": "./catalog-common-types/alt-id.json"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Categories found",
          "schema": {
            "type": "object",
            "title": "Categories",
            "properties": {
              "categories": {
                "type": "array",
