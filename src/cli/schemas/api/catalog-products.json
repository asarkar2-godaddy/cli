    {
      "operationId": "getProducts",
      "method": "GET",
      "path": "/stores/{storeId}/products",
      "summary": "Get products",
      "description": "This endpoint can be used to retrieve the list of products for a specific store using the store ID.",
      "parameters": [
        {
          "name": "includeDeleted",
          "in": "query",
          "required": false,
          "description": "If true, includes deleted products.",
          "schema": {
            "type": "boolean"
          }
        },
        {
          "name": "includeChildProducts",
          "in": "query",
          "required": false,
          "description": "If true, includes child products.\n\n*Note:* It will be ignored when sku, altId or parentId are present.\n",
          "schema": {
            "type": "boolean"
          }
        },
        {
          "name": "type",
          "in": "query",
          "required": false,
          "description": "Filter results to only include a product with this type",
          "schema": {
            "type": "string",
            "description": "The type of product, can be physical, digital, service, or giftcard"
          }
        },
        {
          "name": "ids",
          "in": "query",
          "required": false,
          "description": "Filter results to only include products that have these UUIDs (comma-separated list).\n\n*Note:* Pagination is currently not supported when using this filter.\n",
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "searchTerm",
          "in": "query",
          "required": false,
          "description": "Match different fields in inclusive fashion (OR).\n\n*Note:* Currently only supported on name and SKU.\n",
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "name",
          "in": "query",
          "required": false,
          "description": "Filter results to only include a product with this name (URL encoded)",
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "sku",
          "in": "query",
          "required": false,
          "description": "Filter results to only have a product with this sku",
          "schema": {
            "$ref": "./catalog-common-types/sku.json"
          }
        },
        {
          "name": "altId",
          "in": "query",
          "required": false,
          "description": "Filter results to only include a product with this altId",
          "schema": {
            "$ref": "./catalog-common-types/alt-id.json"
          }
        },
        {
          "name": "categoryId",
          "in": "query",
          "required": false,
          "description": "Filter results to only include products in this category.\n\n*Note:* Pagination is currently not supported when using this filter.\n",
          "schema": {
            "$ref": "./common-types/v1/schemas/json/uuid.json"
          }
        },
        {
          "name": "channelId",
          "in": "query",
          "required": false,
          "description": "Filter results to only include products in this channel",
          "schema": {
            "$ref": "./common-types/v1/schemas/json/uuid.json"
          }
        },
        {
          "name": "parentId",
          "in": "query",
          "required": false,
          "description": "Filter results to only include variants with this id as their parentId",
          "schema": {
            "$ref": "./common-types/v1/schemas/json/uuid.json"
          }
        },
        {
          "name": "externalIdType",
          "in": "query",
          "required": false,
          "description": "Filter results based on externalIdType, must be used with externalIdValue",
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "externalIdValue",
          "in": "query",
          "required": false,
          "description": "Filter results based on externalIdValue, must be used with externalIdType",
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "sortBy",
          "in": "query",
          "required": false,
          "description": "Returns products by sortBy property",
          "schema": {
            "type": "string",
            "enum": ["updatedAt", "name", "price"]
          }
        },
        {
          "name": "sortOrder",
          "in": "query",
          "required": false,
          "description": "Return sorted products in descending or ascending order",
          "schema": {
            "type": "string",
            "enum": ["asc", "desc"]
          }
        },
        {
          "name": "updatedAtStart",
          "in": "query",
          "required": false,
          "description": "Filter results to only include products with an updatedAt timestamp after or at the provided timestamp",
          "schema": {
            "$ref": "./common-types/v1/schemas/yaml/date-time.yaml"
          }
        },
        {
          "name": "updatedAtEnd",
          "in": "query",
          "required": false,
          "description": "Filter results to only include products with an updatedAt timestamp before or at the provided timestamp",
          "schema": {
            "$ref": "./common-types/v1/schemas/yaml/date-time.yaml"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Products found",
          "schema": {
            "type": "object",
            "title": "Products",
            "properties": {
              "products": {
                "type": "array",
                "items": {
                  "$ref": "./models/Product.yaml#/components/schemas/Product"
                }
              },
              "pagination": {
                "$ref": "./http/Common.yaml#/components/schemas/Pagination"
              }
            }
          }
        },
        "401": {
          "description": "See ./http/Error.yaml#/components/responses/401"
        },
        "404": {
          "description": "See ./http/Error.yaml#/components/responses/404"
        },
        "500": {
          "description": "See ./http/Error.yaml#/components/responses/500"
        }
      },
      "scopes": ["commerce.product:read"]
    },
    {
      "operationId": "postProducts",
      "method": "POST",
      "path": "/stores/{storeId}/products",
      "summary": "Create a new product",
