{
  "name": "catalog-products",
  "title": "Catalog Products API",
  "description": "This API allows you to create, update and manage categories, products and product associations.",
  "version": "1.3.0",
  "baseUrl": "https://api.godaddy.com/v1/commerce",
  "endpoints": [
    {
      "operationId": "getAssociations",
      "method": "GET",
      "path": "/stores/{storeId}/associations",
      "summary": "Get associations",
      "description": "This endpoint can be used to retrieve a list of product associations using the store ID.",
      "parameters": [
        {
          "name": "type",
          "in": "query",
          "required": false,
          "description": "Filter associations by `type`",
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "sortBy",
          "in": "query",
          "required": false,
          "description": "Sort associations by name, last updated, or sequence\n\n*Note:* when querying associations, `type` defaults to `category` if not provided\n",
          "schema": {
            "type": "string",
            "default": "updated_at",
            "enum": ["updated_at", "name", "sequence"]
          }
        },
        {
          "name": "sortOrder",
          "in": "query",
          "required": false,
          "description": "Sort associations in descending or ascending order",
          "schema": {
            "type": "string",
            "default": "desc",
            "enum": ["asc", "desc"]
          }
        },
        {
          "name": "altId",
          "in": "query",
          "required": false,
          "description": "Filter associations by `altId` (`type` is required or it defaults to `category`)",
          "schema": {
            "$ref": "./catalog-common-types/alt-id.json"
          }
        },
        {
          "name": "parentId",
          "in": "query",
          "required": false,
          "description": "Filter associations by `parentId`",
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Associations found",
          "schema": {
            "type": "object",
            "title": "Associations",
            "properties": {
              "associations": {
                "type": "array",
                "items": {
                  "$ref": "./models/Association.yaml"
                }
              },
              "pagination": {
                "$ref": "./http/Common.yaml#/components/schemas/Pagination"
              }
            }
          }
        },
        "401": {
          "description": "See ./http/Error.yaml#/components/responses/401"
        },
        "404": {
          "description": "See ./http/Error.yaml#/components/responses/404"
        },
        "500": {
          "description": "See ./http/Error.yaml#/components/responses/500"
        }
      },
      "scopes": ["commerce.category:read"]
    },
    {
      "operationId": "postAssociation",
      "method": "POST",
      "path": "/stores/{storeId}/associations",
      "summary": "Create a new association",
      "description": "Create a new product association to connect products within a catalog using the store ID.",
      "requestBody": {
        "required": true,
        "description": "Properties to create an association",
        "contentType": "application/json",
        "schema": {
          "$ref": "./models/Association.yaml",
          "required": ["type", "name", "depth"]
        }
      },
      "responses": {
        "201": {
          "description": "Association created",
          "schema": {
            "type": "object",
            "title": "AssociationCreated",
            "properties": {
              "association": {
                "$ref": "./models/Association.yaml"
              }
            }
          }
        },
        "401": {
          "description": "See ./http/Error.yaml#/components/responses/401"
        },
        "404": {
          "description": "See ./http/Error.yaml#/components/responses/404"
        },
        "409": {
          "description": "See ./http/CustomResponse.yaml#/components/responses/AssociationAlreadyExists"
        },
        "422": {
          "description": "See ./http/Error.yaml#/components/responses/422"
        },
        "500": {
          "description": "See ./http/Error.yaml#/components/responses/500"
        }
      },
      "scopes": ["commerce.category:write"]
    },
