      "operationId": "deleteAssociation",
      "method": "DELETE",
      "path": "/stores/{storeId}/associations/{associationId}",
      "summary": "Delete an association by ID",
      "description": "This endpoint can be used to delete a product association for a store using the store and association IDs.",
