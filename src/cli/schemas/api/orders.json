        {
          "name": "sortOrder",
          "in": "query",
          "required": false,
          "description": "Sort direction",
          "schema": {
            "type": "string",
            "description": "Sort direction",
            "enum": ["ASC", "DESC"],
            "default": "ASC"
          }
        }
